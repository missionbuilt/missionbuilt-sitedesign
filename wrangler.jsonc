/**
 * Cloudflare Pages config for the missionbuilt static site.
 *
 * The site is fully static (Astro `output: 'static'`). `pages_build_output_dir`
 * tells wrangler where the built assets live so `wrangler pages deploy` works
 * without a positional argument.
 */
{
  "name": "missionbuilt",
  "compatibility_date": "2026-05-10",
  "pages_build_output_dir": "./dist"
}
