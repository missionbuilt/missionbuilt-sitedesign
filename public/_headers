# Cloudflare Pages — response headers.
#
# Hashed bundles under /_astro can long-cache forever (their filenames change
# with content). Top-level named assets (favicons, og-image, manifest, PDFs)
# must NOT long-cache — they're referenced by stable names, so an aggressive
# cache strands old versions in browsers for up to a year when we update them.

/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Top-level named assets: short cache so updates propagate within a day.
/favicon.ico
  Cache-Control: public, max-age=86400, must-revalidate

/favicon.svg
  Cache-Control: public, max-age=86400, must-revalidate

/apple-touch-icon.png
  Cache-Control: public, max-age=86400, must-revalidate

/icon-192.png
  Cache-Control: public, max-age=86400, must-revalidate

/icon-512.png
  Cache-Control: public, max-age=86400, must-revalidate

/og-image.jpg
  Cache-Control: public, max-age=86400, must-revalidate

/site.webmanifest
  Cache-Control: public, max-age=3600, must-revalidate

/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: interest-cohort=()
