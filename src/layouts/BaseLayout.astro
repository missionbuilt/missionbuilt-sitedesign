---
/**
 * BaseLayout — wraps every page with <html>, <head>, fonts, global styles.
 * Uses `bg` slot if a page wants a custom ambient background behind content.
 */
interface Props {
  title?: string;
  description?: string;
  /** Active top-nav link key: 'book' | 'chapters' | 'about' | 'source' */
  active?: 'book' | 'chapters' | 'about' | 'source' | undefined;
}

const {
  title = 'Mission Built · A Field Guide for Building Things That Matter',
  description = "An open-source philosophy forged through reps in the gym and lessons from the field. By Mike Nichols.",
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />

    {/* Open Graph */}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://missionbuilt.io/" />

    {/* Theme color — match charcoal bg so mobile chrome blends */}
    <meta name="theme-color" content="#171513" />

    {/* Fonts: Oswald (display), Merriweather (serif body), JetBrains Mono (mono) */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600;700&family=Merriweather:ital,wght@0,300;0,400;0,700;1,300;1,400;1,700&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    {/* Favicon: 32x32 charcoal canvas with a 14x14 oxblood square centered */}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <slot />
    <style is:global>
      @import "../styles/global.css";
    </style>
  </body>
</html>
