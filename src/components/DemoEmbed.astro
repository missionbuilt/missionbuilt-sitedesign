---
/**
 * DemoEmbed.astro
 * Embeds a skill demo iframe with an expand-to-lightbox button.
 * Used on all three skill pages: spotter, warmup, approach.
 */
interface Props {
  src: string;
  title: string;
  caption: string;
}
const { src, title, caption } = Astro.props;
---

<div class="demo-wrap">
  <iframe
    class="demo-frame"
    src={src}
    title={title}
    loading="lazy"
    scrolling="yes"
  ></iframe>
  <div class="demo-bar">
    <p class="demo-caption">{caption}</p>
    <button class="demo-expand-btn" aria-label="Expand demo">⤢ EXPAND</button>
  </div>
</div>

<!-- Lightbox -->
<div class="demo-lightbox" id="demo-lightbox" aria-hidden="true" aria-modal="true" role="dialog">
  <div class="demo-lb-backdrop"></div>
  <div class="demo-lb-inner">
    <div class="demo-lb-header">
      <span class="demo-lb-label">{title}</span>
      <button class="demo-lb-close" aria-label="Close demo">✕ CLOSE</button>
    </div>
    <iframe
      class="demo-lb-frame"
      src=""
      title={title}
      scrolling="yes"
    ></iframe>
  </div>
</div>

<style>
  /* ── Embedded iframe strip ── */
  .demo-wrap {
    margin-top: 28px;
    border: 1px solid var(--color-rule);
    border-left: 3px solid var(--color-blood);
  }
  .demo-frame {
    display: block;
    width: 100%;
    height: 680px;
    border: none;
    background: var(--color-panel);
  }
  .demo-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: var(--color-panel);
    border-top: 1px solid var(--color-rule);
    padding: 0 12px 0 0;
  }
  .demo-caption {
    margin: 0;
    padding: 10px 16px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-chalk-faint);
  }
  .demo-expand-btn {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-chalk-faint);
    background: none;
    border: 1px solid var(--color-rule);
    padding: 5px 10px;
    cursor: pointer;
    white-space: nowrap;
    flex-shrink: 0;
    transition: color 120ms, border-color 120ms;
  }
  .demo-expand-btn:hover {
    color: var(--color-blood);
    border-color: var(--color-blood);
  }

  /* ── Lightbox ── */
  .demo-lightbox {
    position: fixed;
    inset: 0;
    z-index: 99998;
    display: none;
    align-items: center;
    justify-content: center;
  }
  .demo-lightbox.is-open {
    display: flex;
  }
  .demo-lb-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.88);
    cursor: pointer;
  }
  .demo-lb-inner {
    position: relative;
    z-index: 1;
    width: 95vw;
    height: 94vh;
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-rule);
    border-left: 3px solid var(--color-blood);
    background: var(--color-panel);
  }
  .demo-lb-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 12px 8px 16px;
    border-bottom: 1px solid var(--color-rule);
    flex-shrink: 0;
  }
  .demo-lb-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-chalk-faint);
  }
  .demo-lb-close {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-chalk-faint);
    background: none;
    border: 1px solid var(--color-rule);
    padding: 5px 10px;
    cursor: pointer;
    transition: color 120ms, border-color 120ms;
  }
  .demo-lb-close:hover {
    color: var(--color-blood);
    border-color: var(--color-blood);
  }
  .demo-lb-frame {
    flex: 1;
    width: 100%;
    border: none;
    display: block;
  }
</style>

<script>
  const expandBtn  = document.querySelector('.demo-expand-btn') as HTMLButtonElement | null;
  const lightbox   = document.getElementById('demo-lightbox') as HTMLDivElement | null;
  const backdrop   = lightbox?.querySelector('.demo-lb-backdrop') as HTMLDivElement | null;
  const closeBtn   = lightbox?.querySelector('.demo-lb-close') as HTMLButtonElement | null;
  const lbFrame    = lightbox?.querySelector('.demo-lb-frame') as HTMLIFrameElement | null;
  const demoFrame  = document.querySelector('.demo-frame') as HTMLIFrameElement | null;

  function openLightbox() {
    if (!lightbox || !lbFrame || !demoFrame) return;
    lbFrame.src = demoFrame.src;
    lightbox.classList.add('is-open');
    lightbox.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    if (!lightbox || !lbFrame) return;
    lightbox.classList.remove('is-open');
    lightbox.setAttribute('aria-hidden', 'true');
    lbFrame.src = '';
    document.body.style.overflow = '';
  }

  expandBtn?.addEventListener('click', openLightbox);
  backdrop?.addEventListener('click', closeLightbox);
  closeBtn?.addEventListener('click', closeLightbox);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeLightbox();
  });
</script>
