---
/**
 * DemoEmbed.astro
 * Embeds a skill demo iframe with an expand-to-lightbox button.
 * Used on all three skill pages: spotter, warmup, approach.
 */
interface Props {
  src: string;
  title: string;
  caption: string;
}
const { src, title, caption } = Astro.props;

// Unique ID per instance so multiple embeds on a page don't collide
const uid = Math.random().toString(36).slice(2, 8);
---

<div class="demo-wrap" data-demo-uid={uid}>
  <div class="demo-iframe-wrap">
    <iframe
      class="demo-frame"
      src={src}
      title={title}
      loading="lazy"
      scrolling="yes"
    ></iframe>
    <button
      class="demo-expand-btn"
      data-uid={uid}
      aria-label="Expand demo to full screen"
    >
      ⤢ EXPAND
    </button>
  </div>
  <div class="demo-bar">
    <p class="demo-caption">{caption}</p>
  </div>
</div>

<!-- Lightbox — rendered outside demo-wrap so it can cover the full viewport -->
<div class="demo-lightbox" id={`demo-lb-${uid}`} aria-hidden="true" aria-modal="true" role="dialog">
  <div class="demo-lb-backdrop" data-uid={uid}></div>
  <div class="demo-lb-inner">
    <div class="demo-lb-header">
      <span class="demo-lb-label">{title}</span>
      <button class="demo-lb-close" data-uid={uid}>✕ CLOSE</button>
    </div>
    <iframe
      class="demo-lb-frame"
      id={`demo-lb-frame-${uid}`}
      src=""
      title={title}
      scrolling="yes"
    ></iframe>
  </div>
</div>

<style>
  /* ── Demo wrapper ── */
  .demo-wrap {
    margin-top: 28px;
    border: 1px solid var(--color-rule);
    border-left: 3px solid var(--color-blood);
  }

  /* Position context for the expand badge */
  .demo-iframe-wrap {
    position: relative;
    display: block;
    line-height: 0; /* collapse whitespace under iframe */
  }

  .demo-frame {
    display: block;
    width: 100%;
    height: 680px;
    border: none;
    background: var(--color-panel);
  }

  /* ── Expand badge — oxblood, top-right corner, always visible ── */
  .demo-expand-btn {
    position: absolute;
    top: 12px;
    right: 12px;
    z-index: 10;
    background: var(--color-blood, #a8211a);
    color: #fffaeb;
    border: none;
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 7px 13px;
    cursor: pointer;
    opacity: 0.92;
    transition: opacity 120ms, background 120ms;
    pointer-events: auto;
  }
  .demo-expand-btn:hover {
    opacity: 1;
    background: #c02a20;
  }

  /* ── Caption strip ── */
  .demo-bar {
    background: var(--color-panel, #171513);
    border-top: 1px solid var(--color-rule);
    padding: 0;
  }
  .demo-caption {
    margin: 0;
    padding: 10px 16px;
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-chalk-faint);
  }

  /* ── Lightbox ── */
  .demo-lightbox {
    position: fixed;
    inset: 0;
    z-index: 99998;
    display: none;
    align-items: center;
    justify-content: center;
  }
  .demo-lightbox.is-open {
    display: flex;
  }
  .demo-lb-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.9);
    cursor: pointer;
  }
  .demo-lb-inner {
    position: relative;
    z-index: 1;
    width: 95vw;
    height: 94vh;
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-rule);
    border-left: 3px solid var(--color-blood);
    background: var(--color-panel);
  }
  .demo-lb-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 12px 8px 16px;
    border-bottom: 1px solid var(--color-rule);
    flex-shrink: 0;
  }
  .demo-lb-label {
    font-family: var(--font-mono, monospace);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-chalk-faint);
  }
  .demo-lb-close {
    font-family: var(--font-mono, monospace);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #fffaeb;
    background: var(--color-blood, #a8211a);
    border: none;
    padding: 6px 12px;
    cursor: pointer;
    transition: background 120ms;
  }
  .demo-lb-close:hover {
    background: #c02a20;
  }
  .demo-lb-frame {
    flex: 1;
    width: 100%;
    border: none;
    display: block;
  }
</style>

<script>
  // Use data-uid to scope each instance independently
  document.querySelectorAll<HTMLButtonElement>('.demo-expand-btn[data-uid]').forEach((btn) => {
    const uid = btn.dataset.uid!;
    const lightbox  = document.getElementById(`demo-lb-${uid}`) as HTMLElement | null;
    const lbFrame   = document.getElementById(`demo-lb-frame-${uid}`) as HTMLIFrameElement | null;
    const backdrop  = lightbox?.querySelector<HTMLElement>('.demo-lb-backdrop');
    const closeBtn  = lightbox?.querySelector<HTMLButtonElement>('.demo-lb-close');
    // Find the iframe in the same demo-wrap as this button
    const demoFrame = btn.closest('.demo-wrap')?.querySelector<HTMLIFrameElement>('.demo-frame');

    function open() {
      if (!lightbox || !lbFrame || !demoFrame) return;
      lbFrame.src = demoFrame.src;
      lightbox.classList.add('is-open');
      lightbox.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }

    function close() {
      if (!lightbox || !lbFrame) return;
      lightbox.classList.remove('is-open');
      lightbox.setAttribute('aria-hidden', 'true');
      lbFrame.src = '';
      document.body.style.overflow = '';
    }

    btn.addEventListener('click', open);
    backdrop?.addEventListener('click', close);
    closeBtn?.addEventListener('click', close);
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });
  });
</script>
