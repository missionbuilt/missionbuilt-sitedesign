---
/**
 * The Warmup — standalone page.
 *
 * The live skill from the Loadout. A daily intelligence brief for the first
 * coffee. The page walks through:
 *  - what it does
 *  - three modes (CISO / Product Leader / Custom)
 *  - who it is for
 *  - how link safety works (unique differentiator)
 *  - a demo placeholder
 *  - install (MCP server, four paths)
 *  - trigger phrases
 *  - faq
 *  - also in the kit
 *  - open source / license
 *
 * Color discipline: oxblood for eyebrows, section labels, the closer accent.
 * Army green for the Live tag and the Clean safety verdict.
 * Blood for the Flagged verdict.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import TopNav from '../../components/TopNav.astro';
import DemoEmbed from '../../components/DemoEmbed.astro';

const stats = [
  { key: 'Modes',    value: '3',      href: undefined },
  { key: 'Sections', value: '5',      href: undefined },
  { key: 'License',  value: 'MIT',    href: undefined },
  { key: 'Source',   value: 'GitHub', href: 'https://github.com/missionbuilt/loadout/tree/main/warmup' },
];

type Mode = { num: string; name: string; for: string; body: string; sources: string };
const modes: Mode[] = [
  {
    num: '01',
    name: 'CISO Mode',
    for: 'Security executives',
    body: 'Tell the Warmup your sector and it loads a pre-curated source suite: CISA advisories, the Known Exploited Vulnerabilities catalog, MITRE ATT&CK, CrowdStrike, Palo Alto Unit 42, Elastic Security Labs, Google Mandiant, Microsoft MSTIC, Cisco Talos, and more — plus sector-specific feeds for Healthcare, Financial Services, Energy, Government, and Manufacturing/OT.',
    sources: 'Threat landscape · Emerging threats · Research digest · Industry intel · Social signal',
  },
  {
    num: '02',
    name: 'Product Leader Mode',
    for: 'PMs, CPOs, product executives',
    body: 'Tell the Warmup your product area, vertical, and build type and it loads a source suite tuned for competitive and market intelligence: competitor newsrooms, analyst firms, AI model release trackers, funding and M&A feeds, and the voices worth following in your space.',
    sources: 'Company intel · Competitor moves · AI & tooling · Market & funding · Social signal',
  },
  {
    num: '03',
    name: 'Custom Mode',
    for: 'Everyone else',
    body: 'Describe your morning interests in plain language. Stocks, industry news, competitor blogs, AI model releases, policy changes, local business news — whatever you need to start the day in the loop. The Warmup builds your source suite from scratch and rates every recommended source by trust tier.',
    sources: 'You define the sections',
  },
];

type Audience = { who: string; what: string };
const audience: Audience[] = [
  {
    who: 'Security executives',
    what: 'Threat actors, new CVEs, KEV additions, and sector-specific intelligence — before the first meeting of the day.',
  },
  {
    who: 'Product leaders',
    what: 'Competitor moves, funding rounds, AI releases, and analyst signals — synthesized into one document before your inbox opens.',
  },
  {
    who: 'Founders and operators',
    what: 'A custom source suite built from a plain-language description of what you care about. No configuration files required to start.',
  },
  {
    who: 'Any professional',
    what: 'Anyone who wants to be informed before the first decision of the day — not catching up an hour in.',
  },
];

type SafetyVerdict = { label: string; indicator: 'clean' | 'caution' | 'flagged'; copy: string };
const safetyVerdicts: SafetyVerdict[] = [
  {
    label: 'Clean',
    indicator: 'clean',
    copy: 'No indicators of compromise, no suspicious redirects, no malformed responses. Item included in the brief.',
  },
  {
    label: 'Caution',
    indicator: 'caution',
    copy: 'Something worth noting — an unusual redirect, a certificate anomaly, a domain that recently changed hands. Item included but marked.',
  },
  {
    label: 'Flagged',
    indicator: 'flagged',
    copy: 'Indicators consistent with phishing, malware delivery, or active compromise. Item excluded from the brief body entirely.',
  },
];
---
<BaseLayout
  title="The Warmup · The Loadout · Mission Built"
  description="A daily intelligence brief for your first coffee. Know what moved before you open your inbox. Open-source, MIT-licensed, MCP-compatible."
  active="loadout"
>
  <TopNav active="loadout" />

  <main class="page">
    {/* ---------- BREADCRUMB ---------- */}
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/loadout">The Loadout</a>
      <span aria-hidden="true"> / </span>
      <span class="here">The Warmup</span>
    </nav>

    {/* ---------- HERO ---------- */}
    <section class="hero">
      <p class="eyebrow">
        <span class="dots" aria-hidden="true">▮▮▮</span>
        <span>A skill from the Loadout</span>
        <span class="dots" aria-hidden="true">▮▮▮</span>
      </p>

      <h1 class="display">
        <span>The Warmup</span><span class="dot">.</span>
      </h1>

      <div class="live-tag" aria-label="Live">
        <span class="tag-sq" aria-hidden="true"></span>
        <span>Live</span>
      </div>

      <p class="subtitle">Know what moved before you open your inbox.</p>
    </section>

    {/* ---------- META STRIP ---------- */}
    <section class="meta-strip" aria-label="Warmup at a glance">
      {stats.map((s) => (
        <div class="stat">
          <div class="stat-key">{s.key}</div>
          {s.href ? (
            <a
              class="stat-value linked"
              href={s.href}
              target="_blank"
              rel="noopener"
            >{s.value}<span class="ext" aria-hidden="true"> ↗</span></a>
          ) : (
            <div class="stat-value">{s.value}</div>
          )}
        </div>
      ))}
    </section>

    {/* ---------- WHAT IT DOES ---------- */}
    <section class="block">
      <p class="section-label">What it does</p>
      <h2 class="section-h2">Your briefing. Before the bar.</h2>
      <p class="prose">
        You do not go under the bar cold. In the gym, the warmup is the ten minutes
        that makes the next ninety honest — it tells you what is tight, what needs
        adjustment, and whether today's plan needs to change before the work begins.
      </p>
      <p class="prose">
        The Warmup does the same thing for your workday. Before the first meeting,
        before the first decision — you know what threat actors are active, what
        your competitors shipped, what dropped overnight. The Warmup reads your
        sources, synthesizes what matters, and delivers it as a single live artifact
        you pull with your first coffee. Every item is labeled with its source and
        trust tier. You always know what you are reading and where it came from.
      </p>
    </section>

    <hr class="dashed" />

    {/* ---------- THREE MODES ---------- */}
    <section class="block">
      <p class="section-label">Three modes</p>
      <h2 class="section-h2">Three modes. One brief.</h2>
      <p class="prose">
        Pick the mode that matches your role. Each loads a different source suite
        and structures the brief differently. The output is always a live HTML
        artifact — instrument-panel style, no dashboard chrome.
      </p>

      <div class="modes">
        {modes.map((m) => (
          <article class="mode">
            <div class="mode-num">Mode {m.num}</div>
            <h3 class="mode-name">{m.name}</h3>
            <p class="mode-for">{m.for}</p>
            <p class="mode-body">{m.body}</p>
            <p class="mode-label">Sections</p>
            <p class="mode-sources"><em>{m.sources}</em></p>
          </article>
        ))}
      </div>
    </section>

    <hr class="dashed" />

    {/* ---------- WHO IT'S FOR ---------- */}
    <section class="block">
      <h2 class="section-h2">Who it's for.</h2>
      <div class="audience">
        {audience.map((a) => (
          <article class="audience-cell">
            <h3>{a.who}</h3>
            <p>{a.what}</p>
          </article>
        ))}
      </div>
    </section>

    <hr class="dashed" />

    {/* ---------- LINK SAFETY ---------- */}
    <section class="block">
      <p class="section-label">How link safety works</p>
      <h2 class="section-h2">Every URL scanned. Every time.</h2>
      <p class="prose">
        Every URL cited in the brief is scanned before the artifact renders. The
        brief includes a Link Safety Verification panel showing the result for
        each source domain: scan verdict, number of URLs fetched, and whether
        anything was flagged. Items from flagged sources are excluded from the
        brief body before you ever see them.
      </p>

      <div class="safety-legend">
        {safetyVerdicts.map((v) => (
          <article class="safety-cell">
            <div class="safety-indicator-wrap">
              <span class:list={['safety-indicator', v.indicator]} aria-hidden="true"></span>
              <h3 class:list={['safety-label', v.indicator]}>{v.label}</h3>
            </div>
            <p>{v.copy}</p>
          </article>
        ))}
      </div>
    </section>

    <hr class="dashed" />

    {/* ---------- SEE IT IN ACTION ---------- */}
    <section class="block">
      <p class="section-label">See it in action</p>
      <h2 class="section-h2">The brief, live.</h2>
      <p class="prose">
        The Warmup renders as a live HTML artifact that stays open and refreshes
        each time you run it. Charcoal background, oxblood accents, instrument-panel
        typography. It reads like a field document, not a dashboard.
      </p>

      <DemoEmbed
        src="/demos/warmup.html"
        title="The Warmup — interactive demo"
        caption="Live demo · Example brief · Use ← → or the panel to step through"
      />
    </section>

    <hr class="dashed" />

    {/* ---------- HOW TO USE IT ---------- */}
    <section class="install-block">
      <p class="section-label">How to use it</p>
      <h2 class="section-h2">One connection. Every skill.</h2>
      <p class="install-intro">
        The Warmup is part of the Loadout MCP server. One connection gives you
        every skill in the kit. Any MCP-compatible agent can connect using the
        URL below. Tested and validated in Claude.
      </p>

      <div class="install-url">
        <span class="install-url-label">Server URL</span>
        <code class="install-url-value">https://mcp.missionbuilt.io/sse</code>
      </div>

      <div class="install-options">
        <article class="install-opt">
          <h3>Claude Code · CLI</h3>
          <p>If you have Claude Code installed, run this in your terminal:</p>
          <pre class="install-opt-code">claude mcp add loadout https://mcp.missionbuilt.io/sse</pre>
        </article>

        <article class="install-opt">
          <h3>Claude · No CLI</h3>
          <p>Open Claude, then go to <strong>Settings → Connections → Add MCP Server</strong>. Paste the server URL above and save.</p>
        </article>

        <article class="install-opt">
          <h3>Claude Desktop · Config file</h3>
          <p>Add to <code>claude_desktop_config.json</code> under <code>mcpServers</code>:</p>
          <pre class="install-opt-code">{`"loadout": { "url": "https://mcp.missionbuilt.io/sse" }`}</pre>
        </article>

        <article class="install-opt">
          <h3>Cowork</h3>
          <p>Install the Mission Built plugin from the Cowork plugin directory. OAuth sign-in with Google included.</p>
        </article>
      </div>
    </section>

    {/* ---------- TRIGGER PHRASES ---------- */}
    <section class="block">
      <p class="section-label">After you connect</p>
      <h2 class="section-h2">Say this to get started.</h2>
      <p class="prose">The first time, run setup. After that, one phrase pulls your brief.</p>

      <div class="triggers">
        <div class="trigger-row">
          <span class="trigger-mode">First run</span>
          <code class="trigger-phrase">"warmup setup"</code>
        </div>
        <div class="trigger-row">
          <span class="trigger-mode">Daily brief</span>
          <code class="trigger-phrase">"run warmup"</code>
        </div>
        <div class="trigger-row">
          <span class="trigger-mode">Sources</span>
          <code class="trigger-phrase">"show my warmup sources"</code>
        </div>
      </div>
    </section>

    <hr class="dashed" />

    {/* ---------- FAQ ---------- */}
    <section class="block">
      <p class="section-label">Questions</p>
      <h2 class="section-h2">Common questions.</h2>

      <div class="faq">
        <article class="faq-item">
          <h3>Does my config stay on my machine?</h3>
          <p>Yes. Your source list and preferences live in a <code>WARMUP.md</code> file at your project root. It is gitignored and never committed. Nothing about your setup leaves your machine.</p>
        </article>
        <article class="faq-item">
          <h3>Do I need to sign in?</h3>
          <p>Yes. The server uses Google OAuth. You authenticate once when you connect — no separate account creation required.</p>
        </article>
        <article class="faq-item">
          <h3>Can I add my own sources?</h3>
          <p>Yes. Add, remove, or exclude any source at any time using plain-language commands. The config updates automatically and persists to your <code>WARMUP.md</code>.</p>
        </article>
      </div>
    </section>

    <hr class="dashed" />

    {/* ---------- ALSO IN THE KIT ---------- */}
    <section class="block">
      <p class="section-label">Also in the kit</p>
      <h2 class="section-h2">The full Loadout.</h2>

      <div class="related">
        <a href="/loadout/spotter" class="related-card">
          <h3>The Spotter</h3>
          <p>Walk a product epic through nine areas. Get a structured worksheet back — critique notes, accept and skip loop, export that unlocks when every area closes.</p>
          <span class="related-cta">Open →</span>
        </a>
        <a href="/loadout/approach" class="related-card">
          <h3>The Approach</h3>
          <p>A pre-meeting brief for enterprise calls and QBRs. Decision makers, live signals, discovery questions.</p>
          <span class="related-cta">Open →</span>
        </a>
      </div>
    </section>

    <hr class="dashed" />

    {/* ---------- OPEN SOURCE ---------- */}
    <section class="block">
      <h2 class="section-h2">Open source.</h2>
      <p class="prose">
        The Warmup ships under MIT. Use it commercially, adapt it for your team,
        embed it in your product. Source for both the skill and the MCP server lives in
        <a
          class="inline-link"
          href="https://github.com/missionbuilt/loadout"
          target="_blank"
          rel="noopener"
        >github.com/missionbuilt/loadout</a>.
      </p>
      <p class="prose">
        Your config stays generic — the skill reads your <code>WARMUP.md</code> to
        personalize the brief. Pull skill updates without touching your source list.
      </p>
    </section>

    {/* ---------- CLOSER ---------- */}
    <section class="closer">
      <p>
        You do not go under the bar <strong>cold.</strong>
      </p>
    </section>

    {/* ---------- FOOTER ---------- */}
    <footer class="foot">
      <span>Real strength is lifting others</span>
      <a
        href="https://github.com/missionbuilt/loadout"
        target="_blank"
        rel="noopener"
      >github.com/missionbuilt/loadout</a>
    </footer>
  </main>
</BaseLayout>

<style>
  /* ============ BREADCRUMB ============ */
  .breadcrumb {
    padding: 18px var(--pad-page-x) 0;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-chalk-faint);
  }
  .breadcrumb a {
    color: var(--color-chalk-dim);
    transition: color 120ms ease-out;
  }
  .breadcrumb a:hover { color: var(--color-chalk); }
  .breadcrumb .here { color: var(--color-chalk-faint); }

  /* ============ HERO ============ */
  .hero {
    padding: 40px var(--pad-page-x) 28px;
    text-align: center;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    margin: 0 0 18px;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.24em;
    color: var(--color-blood);
    text-transform: uppercase;
  }
  .eyebrow .dots { letter-spacing: 0.04em; opacity: 0.65; }

  .display {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(56px, 11vw, 108px);
    line-height: 0.95;
    letter-spacing: -0.02em;
    color: var(--color-chalk);
    text-transform: uppercase;
  }
  .display .dot { color: var(--color-blood); }

  .live-tag {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 22px;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-army);
  }
  .live-tag .tag-sq {
    width: 8px;
    height: 8px;
    background: var(--color-army);
    display: inline-block;
  }

  .subtitle {
    margin: 22px auto 0;
    max-width: 760px;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(15px, 2.2vw, 22px);
    color: var(--color-chalk-dim);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  /* ============ META STRIP ============ */
  .meta-strip {
    margin: 28px var(--pad-page-x) 0;
    padding: 14px 0;
    border-top: var(--border-thin);
    border-bottom: var(--border-thin);
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    font-family: var(--font-mono);
    font-size: 11px;
    text-align: left;
  }
  .stat-key {
    color: var(--color-chalk-faint);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }
  .stat-value {
    margin-top: 2px;
    color: var(--color-chalk);
    font-family: var(--font-display);
    font-size: 22px;
    letter-spacing: 0.04em;
    display: inline-block;
  }
  .stat-value.linked {
    border-bottom: 1px solid transparent;
    transition: border-bottom-color 120ms ease-out, color 120ms ease-out;
  }
  .stat-value.linked:hover { border-bottom-color: currentColor; }
  .stat-value .ext {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-chalk-faint);
    letter-spacing: 0;
    transition: color 120ms ease-out;
  }
  .stat-value.linked:hover .ext { color: var(--color-chalk); }

  /* ============ BLOCK ============ */
  .block {
    padding: 56px var(--pad-page-x) 0;
    max-width: 1080px;
  }

  .section-label {
    margin: 0 0 14px;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.24em;
    color: var(--color-blood);
    text-transform: uppercase;
  }

  .section-h2 {
    margin: 0 0 18px;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 36px;
    line-height: 1.05;
    letter-spacing: 0.02em;
    color: var(--color-chalk);
    text-transform: uppercase;
  }

  .prose {
    margin: 0 0 14px;
    max-width: 760px;
    font-family: var(--font-serif);
    font-size: 17px;
    line-height: 1.65;
    color: var(--color-chalk-dim);
  }
  .prose strong { color: var(--color-chalk); font-weight: 700; }
  .prose em { font-style: italic; color: var(--color-chalk); }
  .prose code {
    font-family: var(--font-mono);
    font-size: 0.92em;
    color: var(--color-chalk);
    background: var(--color-panel);
    padding: 1px 6px;
  }
  .inline-link {
    color: var(--color-chalk);
    border-bottom: 1px dotted var(--color-rule);
    transition: color 120ms ease-out, border-color 120ms ease-out;
  }
  .inline-link:hover {
    color: var(--color-blood);
    border-bottom-color: var(--color-blood);
  }

  /* ============ MODES GRID ============ */
  .modes {
    margin-top: 28px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-top: var(--border-thin);
    border-bottom: var(--border-thin);
  }
  .mode {
    padding: 28px 28px 32px;
    border-right: var(--border-thin);
  }
  .mode:last-child { border-right: none; }

  .mode-num {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.28em;
    color: var(--color-chalk-faint);
    text-transform: uppercase;
    margin-bottom: 14px;
  }
  .mode-name {
    margin: 0 0 6px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 24px;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--color-chalk);
  }
  .mode-for {
    margin: 0 0 16px;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 13px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-blood);
  }
  .mode-body {
    margin: 0 0 18px;
    font-family: var(--font-serif);
    font-size: 15px;
    line-height: 1.6;
    color: var(--color-chalk-dim);
  }
  .mode-label {
    margin: 18px 0 4px;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-chalk-faint);
  }
  .mode-sources {
    margin: 0;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 14px;
    line-height: 1.55;
    color: var(--color-chalk);
  }

  /* ============ AUDIENCE (2x2) ============ */
  .audience {
    margin-top: 28px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    border-top: var(--border-thin);
    border-bottom: var(--border-thin);
  }
  .audience-cell {
    padding: 24px 28px;
    border-right: var(--border-thin);
    border-bottom: var(--border-thin);
  }
  .audience-cell:nth-child(2n) { border-right: none; }
  .audience-cell:nth-last-child(-n+2) { border-bottom: none; }
  .audience-cell h3 {
    margin: 0 0 10px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 20px;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--color-chalk);
  }
  .audience-cell p {
    margin: 0;
    font-family: var(--font-serif);
    font-size: 15px;
    line-height: 1.6;
    color: var(--color-chalk-dim);
  }

  /* ============ LINK SAFETY ============ */
  .safety-legend {
    margin-top: 28px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-top: var(--border-thin);
    border-bottom: var(--border-thin);
  }
  .safety-cell {
    padding: 24px 28px;
    border-right: var(--border-thin);
  }
  .safety-cell:last-child { border-right: none; }
  .safety-indicator-wrap {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 14px;
  }
  .safety-indicator {
    width: 10px;
    height: 10px;
    display: inline-block;
    flex-shrink: 0;
  }
  .safety-indicator.clean   { background: var(--color-army); }
  .safety-indicator.caution { background: var(--color-chalk-dim); }
  .safety-indicator.flagged { background: var(--color-blood); }
  .safety-label {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 18px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .safety-label.clean   { color: var(--color-army); }
  .safety-label.caution { color: var(--color-chalk); }
  .safety-label.flagged { color: var(--color-blood); }
  .safety-cell p {
    margin: 0;
    font-family: var(--font-serif);
