---
/**
 * The Spotter — standalone page.
 *
 * The live skill from the Loadout. A product epic review tool using
 * nine product-leadership areas. The page walks through:
 *  - what it does
 *  - the two modes (Review / Build)
 *  - who it is for
 *  - the verdict signals (pip system, good lift / no-lift)
 *  - a sample worksheet placeholder
 *  - install (MCP server, four paths)
 *  - open source / license
 *
 * Color discipline: oxblood for the hero period, eyebrows, section
 * labels, the closer accent, the "missing" verdict marks, and the
 * sample corner badge. Army green only for the Live tag under the hero.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import TopNav from '../../components/TopNav.astro';
import DemoEmbed from '../../components/DemoEmbed.astro';

const stats = [
  { key: 'Modes',   value: '2',     href: undefined },
  { key: 'Areas',   value: '9',     href: undefined },
  { key: 'License', value: 'MIT',   href: undefined },
  { key: 'Source',  value: 'GitHub', href: 'https://github.com/missionbuilt/loadout/tree/main/spotter' },
];

type Phase = { num: string; mode: string; when: string; body: string; deliverable: string };
const phases: Phase[] = [
  {
    num: '01',
    mode: 'Review',
    when: 'Before stakeholders see it',
    body:
      'You have a complete epic and need a final pass before sending it for review. The Spotter walks all nine areas, calls verdicts with the powerlifting pip system, and produces an interactive worksheet to work through.',
    deliverable: 'A structured worksheet — critique notes per area, an accept and skip loop, an export that unlocks when every area is closed.',
  },
  {
    num: '02',
    mode: 'Build',
    when: 'Starting from blank',
    body:
      "You have a new initiative and a blank page. The Spotter asks targeted questions for each area and helps you draft an epic that's already area-aware from the first version.",
    deliverable: 'A working first draft, structured against all nine areas.',
  },
];

type Audience = { who: string; what: string };
const audience: Audience[] = [
  {
    who: 'Product managers',
    what:
      'Tightening an epic before sending it for review. Catching gaps before someone senior catches them.',
  },
  {
    who: 'Product leaders',
    what:
      "Calibrating the team's writing without sitting in every working doc. A consistent bar across the org.",
  },
  {
    who: 'Founders and operators',
    what:
      'Building product instincts without a coach. Learning the questions a seasoned PM would ask.',
  },
  {
    who: 'Engineers and designers',
    what:
      "Reading an epic critically before standup. Spotting what is missing before kickoff.",
  },
];

type Pip = 'w' | 'r';

// The legend: two verdict states.
const legend: { label: string; pips: Pip[]; copy: string }[] = [
  { label: 'Good lift', pips: ['w','w','w'], copy: 'The area is well-addressed. Move on.' },
  { label: 'No-lift',   pips: ['r','r','r'], copy: 'The area needs work. The worksheet keeps it open until you close it.' },
];
---
<BaseLayout
  title="The Spotter · The Loadout · Mission Built"
  description="A second pair of eyes on your product epic, from blank page to final review. Open-source, MIT-licensed, MCP-compatible."
  active="loadout"
>
  <TopNav active="loadout" />

  <main class="page">
    {/* ---------- BREADCRUMB ---------- */}
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/loadout">The Loadout</a>
      <span aria-hidden="true"> / </span>
      <span class="here">The Spotter</span>
    </nav>

    {/* ---------- HERO ---------- */}
    <section class="hero">
      <p class="eyebrow">
        <span class="dots" aria-hidden="true">▮▮▮</span>
        <span>A skill from the Loadout</span>
        <span class="dots" aria-hidden="true">▮▮▮</span>
      </p>

      <h1 class="display">
        <span>The Spotter</span><span class="dot">.</span>
      </h1>

      <div class="live-tag" aria-label="Live">
        <span class="tag-sq" aria-hidden="true"></span>
        <span>Live</span>
      </div>

      <p class="subtitle">A structured worksheet for the epic on your desk.</p>
    </section>

    {/* ---------- META STRIP ---------- */}
    <section class="meta-strip" aria-label="Spotter at a glance">
      {stats.map((s) => (
        <div class="stat">
          <div class="stat-key">{s.key}</div>
          {s.href ? (
            <a
              class="stat-value linked"
              href={s.href}
              target="_blank"
              rel="noopener"
            >{s.value}<span class="ext" aria-hidden="true"> ↗</span></a>
          ) : (
            <div class="stat-value">{s.value}</div>
          )}
        </div>
      ))}
    </section>

    {/* ---------- WHAT IT DOES ---------- */}
    <section class="block">
      <p class="section-label">What it does</p>
      <h2 class="section-h2">Walks an epic through nine areas.</h2>
      <p class="prose">
        The Spotter reviews a product epic across nine product-leadership areas —
        user and problem, competitive landscape, strategic differentiation,
        solution approach, holistic impact, packaging and pricing, launch readiness,
        post-launch ownership, and trust, governance, and auditability. It meets you
        wherever the epic is: blank page, rough draft, or nearly done.
      </p>
      <p class="prose">
        The output is an interactive worksheet. Each area shows the relevant excerpt
        from your epic, a pip verdict, and typed critique notes. Accept the ones you
        have addressed. Skip the ones you are setting aside. When every area is closed,
        the export unlocks. Every flag is constructive — never "you missed this,"
        always <em>"you could strengthen this by…"</em>
      </p>
    </section>

    <hr class="dashed" />

    {/* ---------- TWO MODES ---------- */}
    <section class="block">
      <p class="section-label">Two modes</p>
      <h2 class="section-h2">Two modes. One framework.</h2>
      <p class="prose">
        Pick the mode that matches where you are. The nine areas stay the same.
        What the Spotter gives back changes with the mode.
      </p>

      <div class="phases">
        {phases.map((p) => (
          <article class="phase">
            <div class="phase-num">Phase {p.num}</div>
            <h3 class="phase-mode">{p.mode}</h3>
            <p class="phase-when">{p.when}</p>
            <p class="phase-body">{p.body}</p>
            <p class="phase-label">You get back</p>
            <p class="phase-deliverable"><em>{p.deliverable}</em></p>
          </article>
        ))}
      </div>
    </section>

    <hr class="dashed" />

    {/* ---------- WHO IT'S FOR ---------- */}
    <section class="block">
      <h2 class="section-h2">Who it's for.</h2>
      <div class="audience">
        {audience.map((a) => (
          <article class="audience-cell">
            <h3>{a.who}</h3>
            <p>{a.what}</p>
          </article>
        ))}
      </div>
    </section>

    <hr class="dashed" />

    {/* ---------- HOW THE VERDICT WORKS ---------- */}
    <section class="block">
      <p class="section-label">How the verdict works</p>
      <h2 class="section-h2">Three judges. Two verdicts.</h2>
      <p class="prose">
        Borrowed from powerlifting. After each lift, three judges flash white for
        a good lift, red for no-lift. The Spotter does the same for each of the
        nine areas — three pip signals per area, one verdict. Good lift means the
        area is well-addressed. No-lift means the worksheet keeps that area open
        until you work through it and close it yourself.
      </p>

      <div class="legend">
        {legend.map((l) => (
          <article class="legend-cell">
            <div class="legend-marks" aria-hidden="true">
              {l.pips.map((p) => <span class:list={['pip', p === 'w' ? 'pass' : 'miss']}></span>)}
            </div>
            <h3>{l.label}</h3>
            <p>{l.copy}</p>
          </article>
        ))}
      </div>
    </section>

    <hr class="dashed" />

    {/* ---------- SEE IT IN ACTION ---------- */}
    <section class="block">
      <p class="section-label">See it in action</p>
      <h2 class="section-h2">The worksheet, area by area.</h2>
      <p class="prose">
        In Review mode, the Spotter evaluates your epic across all nine areas and
        builds a live worksheet artifact. Each area shows the relevant excerpt,
        a three-pip verdict, and typed critique notes. Work through it at your
        own pace — accept notes you have addressed, skip ones you are setting
        aside, and close each area when you are done. Export unlocks when the
        last area closes.
      </p>

      <DemoEmbed
        src="/demos/spotter.html"
        title="The Spotter — interactive demo"
        caption="Live demo · Example epic · Use ← → or the panel to step through"
      />
    </section>

    <hr class="dashed" />

    {/* ---------- HOW TO USE IT ---------- */}
    <section class="install-block">
      <p class="section-label">How to use it</p>
      <h2 class="section-h2">One connection. Every skill.</h2>
      <p class="install-intro">
        The Spotter is part of the Loadout MCP server. One connection gives you every skill in the kit. Tested on Claude.
      </p>

      <div class="install-url">
        <span class="install-url-label">Server URL</span>
        <code class="install-url-value">https://mcp.missionbuilt.io/sse</code>
      </div>

      <p class="install-verified">✓ Verified on Claude</p>

      <div class="install-options">
        <article class="install-opt">
          <h3>Claude Code · CLI</h3>
          <p>If you have Claude Code installed, run this in your terminal:</p>
          <pre class="install-opt-code">claude mcp add loadout https://mcp.missionbuilt.io/sse</pre>
        </article>

        <article class="install-opt">
          <h3>Claude · No CLI</h3>
          <p>Open Claude, then go to <strong>Settings → Connections → Add MCP Server</strong>. Paste the server URL above and save.</p>
        </article>
      </div>
    </section>

    {/* ---------- TRIGGER PHRASES ---------- */}
    <section class="block">
      <p class="section-label">After you connect</p>
      <h2 class="section-h2">Say this to get started.</h2>
      <p class="prose">Paste your epic into the conversation, then use either phrase. The skill triggers automatically.</p>

      <div class="triggers">
        <div class="trigger-row">
          <span class="trigger-mode">Review</span>
          <code class="trigger-phrase">"run the spotter on this epic"</code>
        </div>
        <div class="trigger-row">
          <span class="trigger-mode">Build</span>
          <code class="trigger-phrase">"build me an epic for [initiative]"</code>
        </div>
      </div>
    </section>

    <hr class="dashed" />

    {/* ---------- FAQ ---------- */}
    <section class="block">
      <p class="section-label">Questions</p>
      <h2 class="section-h2">Common questions.</h2>

      <div class="faq">
        <article class="faq-item">
          <h3>Is my epic stored anywhere?</h3>
          <p>No. Your content is processed in memory and discarded after the worksheet is built. Nothing is written to a database or logged.</p>
        </article>
        <article class="faq-item">
          <h3>Do I need to sign in?</h3>
          <p>Yes. The server uses Google OAuth. You authenticate once when you connect — no separate account creation required.</p>
        </article>
        <article class="faq-item">
          <h3>Does this work with agents other than Claude?</h3>
          <p>Yes. The Loadout is a standard MCP server and works with any MCP-compatible agent. It has been tested and validated in Claude.</p>
        </article>
      </div>
    </section>

    <hr class="dashed" />

    {/* ---------- ALSO IN THE KIT ---------- */}
    <section class="block">
      <p class="section-label">Also in the kit</p>
      <h2 class="section-h2">The full Loadout.</h2>

      <div class="related">
        <a href="/loadout/warmup" class="related-card">
          <h3>The Warmup</h3>
          <p>A daily intelligence brief for your first coffee. Curated sources, link safety scanning, live artifact.</p>
          <span class="related-cta">Open →</span>
        </a>
        <a href="/loadout/approach" class="related-card">
          <h3>The Approach</h3>
          <p>A pre-meeting brief for enterprise calls and QBRs. Decision makers, live signals, discovery questions.</p>
          <span class="related-cta">Open →</span>
        </a>
      </div>
    </section>

    <hr class="dashed" />

    {/* ---------- OPEN SOURCE ---------- */}
    <section class="block">
      <h2 class="section-h2">Open source.</h2>
      <p class="prose">
        The Spotter ships under MIT. Use it commercially, adapt it for your team,
        embed it in your product. Source for both the skill and the MCP server lives in
        <a
          class="inline-link"
          href="https://github.com/missionbuilt/loadout"
          target="_blank"
          rel="noopener"
        >github.com/missionbuilt/loadout</a>.
        Attribution to the writers and skills whose thinking informed it is in
        <code>spotter/ATTRIBUTION.md</code>.
      </p>
      <p class="prose">
        Customize for your team by adding a <code>CLAUDE.md</code> at your project
        root with your tier names, competitor set, and product taxonomy. The skill
        stays generic. Your context stays local.
      </p>
    </section>

    {/* ---------- CLOSER ---------- */}
    <section class="closer">
      <p>
        A spotter lifts the lifter. <strong>Not the bar.</strong>
      </p>
    </section>

    {/* ---------- FOOTER ---------- */}
    <footer class="foot">
      <span>Real strength is lifting others</span>
      <a
        href="https://github.com/missionbuilt/loadout"
        target="_blank"
        rel="noopener"
      >github.com/missionbuilt/loadout</a>
    </footer>
  </main>
</BaseLayout>

<style>
  /* ============ BREADCRUMB ============ */
  .breadcrumb {
    padding: 18px var(--pad-page-x) 0;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-chalk-faint);
  }
  .breadcrumb a {
    color: var(--color-chalk-dim);
    transition: color 120ms ease-out;
  }
  .breadcrumb a:hover { color: var(--color-chalk); }
  .breadcrumb .here { color: var(--color-chalk-faint); }

  /* ============ HERO ============ */
  .hero {
    padding: 40px var(--pad-page-x) 28px;
    text-align: center;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    margin: 0 0 18px;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.24em;
    color: var(--color-blood);
    text-transform: uppercase;
  }
  .eyebrow .dots {
    letter-spacing: 0.04em;
    opacity: 0.65;
  }

  .display {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(56px, 11vw, 108px);
    line-height: 0.95;
    letter-spacing: -0.02em;
    color: var(--color-chalk);
    text-transform: uppercase;
  }
  .display .dot { color: var(--color-blood); }

  .live-tag {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 22px;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-army);
  }
  .live-tag .tag-sq {
    width: 8px;
    height: 8px;
    background: var(--color-army);
    display: inline-block;
  }

  .subtitle {
    margin: 22px auto 0;
    max-width: 760px;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(15px, 2.2vw, 22px);
    color: var(--color-chalk-dim);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  /* ============ META STRIP ============ */
  .meta-strip {
    margin: 28px var(--pad-page-x) 0;
    padding: 14px 0;
    border-top: var(--border-thin);
    border-bottom: var(--border-thin);
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    font-family: var(--font-mono);
    font-size: 11px;
    text-align: left;
  }
  .stat-key {
    color: var(--color-chalk-faint);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }
  .stat-value {
    margin-top: 2px;
    color: var(--color-chalk);
    font-family: var(--font-display);
    font-size: 22px;
    letter-spacing: 0.04em;
    display: inline-block;
  }
  .stat-value.linked {
    border-bottom: 1px solid transparent;
    transition: border-bottom-color 120ms ease-out, color 120ms ease-out;
  }
  .stat-value.linked:hover { border-bottom-color: currentColor; }
  .stat-value .ext {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-chalk-faint);
    letter-spacing: 0;
    transition: color 120ms ease-out;
  }
  .stat-value.linked:hover .ext { color: var(--color-chalk); }

  /* ============ BLOCK ============ */
  .block {
    padding: 56px var(--pad-page-x) 0;
    max-width: 1080px;
  }

  .section-label {
    margin: 0 0 14px;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.24em;
    color: var(--color-blood);
    text-transform: uppercase;
  }

  .section-h2 {
    margin: 0 0 18px;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 36px;
    line-height: 1.05;
    letter-spacing: 0.02em;
    color: var(--color-chalk);
    text-transform: uppercase;
  }

  .prose {
    margin: 0 0 14px;
    max-width: 760px;
    font-family: var(--font-serif);
    font-size: 17px;
    line-height: 1.65;
    color: var(--color-chalk-dim);
  }
  .prose strong { color: var(--color-chalk); font-weight: 700; }
  .prose em { font-style: italic; color: var(--color-chalk); }
  .prose code,
  .install-body code {
    font-family: var(--font-mono);
    font-size: 0.92em;
    color: var(--color-chalk);
    background: var(--color-panel);
    padding: 1px 6px;
  }
  .inline-link {
    color: var(--color-chalk);
    border-bottom: 1px dotted var(--color-rule);
    transition: color 120ms ease-out, border-color 120ms ease-out;
  }
  .inline-link:hover {
    color: var(--color-blood);
    border-bottom-color: var(--color-blood);
  }

  /* ============ PHASES GRID ============ */
  .phases {
    margin-top: 28px;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    border-top: var(--border-thin);
    border-bottom: var(--border-thin);
  }
  .phase {
    padding: 28px 28px 32px;
    border-right: var(--border-thin);
  }
  .phase:last-child { border-right: none; }

  .phase-num {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.28em;
    color: var(--color-chalk-faint);
    text-transform: uppercase;
    margin-bottom: 14px;
  }
  .phase-mode {
    margin: 0 0 6px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 28px;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--color-chalk);
  }
  .phase-when {
    margin: 0 0 16px;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 13px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-blood);
  }
  .phase-body {
    margin: 0 0 18px;
    font-family: var(--font-serif);
    font-size: 15px;
    line-height: 1.6;
    color: var(--color-chalk-dim);
  }
  .phase-label {
    margin: 18px 0 4px;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-chalk-faint);
  }
  .phase-deliverable {
    margin: 0;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 15px;
    line-height: 1.55;
    color: var(--color-chalk);
  }

  /* ============ AUDIENCE (2x2) ============ */
  .audience {
    margin-top: 28px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    border-top: var(--border-thin);
    border-bottom: var(--border-thin);
  }
  .audience-cell {
    padding: 24px 28px;
    border-right: var(--border-thin);
    border-bottom: var(--border-thin);
  }
  .audience-cell:nth-child(2n) { border-right: none; }
  .audience-cell:nth-last-child(-n+2) { border-bottom: none; }
  .audience-cell h3 {
    margin: 0 0 10px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 20px;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--color-chalk);
  }
  .audience-cell p {
    margin: 0;
    font-family: var(--font-serif);
    font-size: 15px;
    line-height: 1.6;
    color: var(--color-chalk-dim);
  }

  /* ============ PIPS (small squares) ============ */
  .pip {
    display: inline-block;
    width: 10px;
    height: 10px;
    border: 1px solid var(--color-rule);
    margin-right: 3px;
  }
  .pip.pass { background: var(--color-chalk); border-color: var(--color-chalk); }
  .pip.miss { background: var(--color-blood); border-color: var(--color-blood); }

  /* ============ LEGEND (2 cells) ============ */
  .legend {
    margin-top: 28px;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    border-top: var(--border-thin);
    border-bottom: var(--border-thin);
  }
  .legend-cell {
    padding: 24px 28px;
    border-right: var(--border-thin);
  }
  .legend-cell:last-child { border-right: none; }
  .legend-marks { margin-bottom: 14px; line-height: 1; }
  .legend-cell h3 {
    margin: 0 0 8px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 18px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-chalk);
  }
  .legend-cell p {
    margin: 0;
    font-family: var(--font-serif);
    font-size: 14px;
    line-height: 1.55;
    color: var(--color-chalk-dim);
  }

  /* ============ INSTALL BLOCK ============ */
  .install-block {
    padding: 56px var(--pad-page-x) 0;
    max-width: 1080px;
  }

  .install-intro {
    margin: 0 0 28px;
    max-width: 720px;
    font-family: var(--font-serif);
    font-size: 17px;
    line-height: 1.65;
    color: var(--color-chalk-dim);
  }

  .install-url {
    display: flex;
    align-items: center;
    gap: 18px;
    margin-bottom: 28px;
    padding: 14px 20px;
    background: var(--color-panel);
    border: var(--border-thin);
    border-left: 3px solid var(--color-blood);
  }

  .install-url-label {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-chalk-faint);
    white-space: nowrap;
  }

  .install-url-value {
    font-family: var(--font-mono);
    font-size: 14px;
    color: var(--color-chalk);
    letter-spacing: 0.04em;
  }

  .install-verified {
    margin: 0 0 24px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
