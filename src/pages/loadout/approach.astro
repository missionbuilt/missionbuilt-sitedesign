---
/**
 * The Approach — standalone page.
 *
 * The live skill from the Loadout. A pre-call intelligence brief for sellers
 * and technical sellers. The page walks through:
 *  - what it does
 *  - two acts (AE above fold / SE below)
 *  - who it is for
 *  - the MEDDPICC scorecard (unique differentiator)
 *  - a demo placeholder
 *  - install (MCP server, four paths)
 *  - trigger phrases
 *  - faq
 *  - also in the kit
 *  - open source / license
 *
 * Color discipline: oxblood for eyebrows, section labels, the closer accent.
 * Army green for the Live tag and Confirmed MEDDPICC state.
 * Blood for Unknown MEDDPICC state.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import TopNav from '../../components/TopNav.astro';
import DemoEmbed from '../../components/DemoEmbed.astro';

const stats = [
  { key: 'Sections', value: '9',      href: undefined },
  { key: 'Acts',     value: '2',      href: undefined },
  { key: 'License',  value: 'MIT',    href: undefined },
  { key: 'Source',   value: 'GitHub', href: 'https://github.com/missionbuilt/loadout/tree/main/the-approach' },
];

type Act = { num: string; name: string; audience: string; sections: string[]; body: string };
const acts: Act[] = [
  {
    num: '01',
    name: 'The AE Half',
    audience: 'Account executives',
    body: 'Business intelligence above the fold. Company snapshot, leadership and the buyer, financial posture, industry context, and recent signal — everything you need to open the call with authority and ask the right questions.',
    sections: ['Company snapshot', 'Leadership & the buyer', 'Financial posture', 'Industry context', 'Recent signal'],
  },
  {
    num: '02',
    name: 'The SE Half',
    audience: 'Sales engineers',
    body: 'Technical depth below the fold. Stack and integrations, public security events, demo prep, and an opener with discovery questions grounded in real public signals — so the SE walks in with a plan, not a script.',
    sections: ['Stack & integrations', 'Public security events', 'Demo prep', 'Opener & discovery'],
  },
];

type Audience = { who: string; what: string };
const audience: Audience[] = [
  {
    who: 'Account executives',
    what: 'Company intel, leadership profiles, financial posture, and competitive context — before the deck, before the discovery script.',
  },
  {
    who: 'Sales engineers',
    what: 'Tech stack, public security events, and a demo prep section tied to what is already in their environment.',
  },
  {
    who: 'Founders doing outbound',
    what: 'Research and discovery questions without a full sales team. Walk into the first conversation already inside the lift.',
  },
  {
    who: 'Anyone in an important meeting',
    what: 'Not just sales. QBRs, executive sponsors, partner calls — any time walking in cold is not an option.',
  },
];

type MeddpiccState = 'confirmed' | 'partial' | 'unknown';
type MeddpiccDimension = { letter: string; name: string; state: MeddpiccState };
const meddpicc: MeddpiccDimension[] = [
  { letter: 'M', name: 'Metrics',          state: 'confirmed' },
  { letter: 'E', name: 'Economic Buyer',   state: 'partial'   },
  { letter: 'D', name: 'Decision Criteria',state: 'partial'   },
  { letter: 'D', name: 'Decision Process', state: 'unknown'   },
  { letter: 'P', name: 'Paper Process',    state: 'unknown'   },
  { letter: 'I', name: 'Identify Pain',    state: 'confirmed' },
  { letter: 'C', name: 'Champion',         state: 'partial'   },
  { letter: 'C', name: 'Competition',      state: 'confirmed' },
];
---
<BaseLayout
  title="The Approach · The Loadout · Mission Built"
  description="A pre-call intelligence brief for sellers and technical sellers. Know the room before you walk in. Open-source, MIT-licensed, MCP-compatible."
  active="loadout"
>
  <TopNav active="loadout" />

  <main class="page">
    {/* ---------- BREADCRUMB ---------- */}
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/loadout">The Loadout</a>
      <span aria-hidden="true"> / </span>
      <span class="here">The Approach</span>
    </nav>

    {/* ---------- HERO ---------- */}
    <section class="hero">
      <p class="eyebrow">
        <span class="dots" aria-hidden="true">▮▮▮</span>
        <span>A skill from the Loadout</span>
        <span class="dots" aria-hidden="true">▮▮▮</span>
      </p>

      <h1 class="display">
        <span>The Approach</span><span class="dot">.</span>
      </h1>

      <div class="live-tag" aria-label="Live">
        <span class="tag-sq" aria-hidden="true"></span>
        <span>Live</span>
      </div>

      <p class="subtitle">Know the room before you walk in.</p>
    </section>

    {/* ---------- META STRIP ---------- */}
    <section class="meta-strip" aria-label="Approach at a glance">
      {stats.map((s) => (
        <div class="stat">
          <div class="stat-key">{s.key}</div>
          {s.href ? (
            <a
              class="stat-value linked"
              href={s.href}
              target="_blank"
              rel="noopener"
            >{s.value}<span class="ext" aria-hidden="true"> ↗</span></a>
          ) : (
            <div class="stat-value">{s.value}</div>
          )}
        </div>
      ))}
    </section>

    {/* ---------- WHAT IT DOES ---------- */}
    <section class="block">
      <p class="section-label">What it does</p>
      <h2 class="section-h2">Walk up already inside the lift.</h2>
      <p class="prose">
        In the gym, the approach to the bar is not incidental — it is deliberate.
        You know your opener. You know your second and your third. You have studied
        the competition. You walk up already inside the lift.
      </p>
      <p class="prose">
        The Approach does the same thing before a sales call. Give it a company
        name and a line of context. It researches the target across nine concurrent
        source categories — company snapshot, leadership, financials, industry
        context, social signal, tech stack, security events, demo prep, and discovery
        — then renders a structured field brief. Two acts in one document: business
        intelligence for the AE above the fold, technical depth for the SE below.
      </p>
    </section>

    <hr class="dashed" />

    {/* ---------- TWO ACTS ---------- */}
    <section class="block">
      <p class="section-label">Brief structure</p>
      <h2 class="section-h2">Two acts. One document.</h2>
      <p class="prose">
        Both halves travel together. Both get read before the call.
      </p>

      <div class="acts">
        {acts.map((a) => (
          <article class="act">
            <div class="act-num">Act {a.num}</div>
            <h3 class="act-name">{a.name}</h3>
            <p class="act-audience">{a.audience}</p>
            <p class="act-body">{a.body}</p>
            <p class="act-label">Sections</p>
            <ul class="act-sections">
              {a.sections.map((s) => <li>{s}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </section>

    <hr class="dashed" />

    {/* ---------- WHO IT'S FOR ---------- */}
    <section class="block">
      <h2 class="section-h2">Who it's for.</h2>
      <div class="audience">
        {audience.map((a) => (
          <article class="audience-cell">
            <h3>{a.who}</h3>
            <p>{a.what}</p>
          </article>
        ))}
      </div>
    </section>

    <hr class="dashed" />

    {/* ---------- MEDDPICC SCORECARD ---------- */}
    <section class="block">
      <p class="section-label">Built from public intel</p>
      <h2 class="section-h2">MEDDPICC. Before the first call.</h2>
      <p class="prose">
        Every brief includes a MEDDPICC scorecard built entirely from public signals.
        Each of the eight qualification dimensions gets a verdict — Confirmed, Partial,
        or Unknown — with a specific next action attached. You walk in knowing what
        you know, what you are guessing, and what you still need to find out.
      </p>

      <div class="meddpicc">
        {meddpicc.map((d) => (
          <div class="medd-row">
            <span class="medd-letter" aria-hidden="true">{d.letter}</span>
            <span class="medd-name">{d.name}</span>
            <span class:list={['medd-state', d.state]}>{d.state.charAt(0).toUpperCase() + d.state.slice(1)}</span>
          </div>
        ))}
      </div>

      <p class="medd-note">Sample scorecard. Your actual brief reflects real public intel on the target company.</p>
    </section>

    <hr class="dashed" />

    {/* ---------- SEE IT IN ACTION ---------- */}
    <section class="block">
      <p class="section-label">See it in action</p>
      <h2 class="section-h2">The brief, before the call.</h2>
      <p class="prose">
        The Approach renders as a live HTML artifact in the Mission Built editorial
        style — cream paper, oxblood accents, Oswald display type, Merriweather
        body, JetBrains Mono for labels. No rounded corners. No drop shadows.
        Reads like a field document, not a CRM screen.
      </p>

      <DemoEmbed
        src="/demos/approach.html"
        title="The Approach — interactive demo"
        caption="Live demo · Example brief · Use ← → or the panel to step through"
      />
    </section>

    <hr class="dashed" />

    {/* ---------- HOW TO USE IT ---------- */}
    <section class="install-block">
      <p class="section-label">How to use it</p>
      <h2 class="section-h2">One connection. Every skill.</h2>
      <p class="install-intro">
        The Approach is part of the Loadout MCP server. One connection gives you every skill in the kit. Tested on Claude.
      </p>

      <div class="install-url">
        <span class="install-url-label">Server URL</span>
        <code class="install-url-value">https://mcp.missionbuilt.io/sse</code>
      </div>

      <p class="install-verified">✓ Verified on Claude</p>

      <div class="install-options">
        <article class="install-opt">
          <h3>Claude Code · CLI</h3>
          <p>If you have Claude Code installed, run this in your terminal:</p>
          <pre class="install-opt-code">claude mcp add loadout https://mcp.missionbuilt.io/sse</pre>
        </article>

        <article class="install-opt">
          <h3>Claude · No CLI</h3>
          <p>Open Claude, then go to <strong>Settings → Connections → Add MCP Server</strong>. Paste the server URL above and save.</p>
        </article>
      </div>
    </section>

    {/* ---------- TRIGGER PHRASES ---------- */}
    <section class="block">
      <p class="section-label">After you connect</p>
      <h2 class="section-h2">Say this to get started.</h2>
      <p class="prose">Give it a company name and a line of context. The brief runs automatically.</p>

      <div class="triggers">
        <div class="trigger-row">
          <span class="trigger-mode">Full brief</span>
          <code class="trigger-phrase">"run the approach on [company]"</code>
        </div>
        <div class="trigger-row">
          <span class="trigger-mode">With context</span>
          <code class="trigger-phrase">"approach for Acme — AE at Elastic, meeting VP of IT Friday"</code>
        </div>
        <div class="trigger-row">
          <span class="trigger-mode">Quick form</span>
          <code class="trigger-phrase">"brief me on [company]"</code>
        </div>
      </div>
    </section>

    <hr class="dashed" />

    {/* ---------- FAQ ---------- */}
    <section class="block">
      <p class="section-label">Questions</p>
      <h2 class="section-h2">Common questions.</h2>

      <div class="faq">
        <article class="faq-item">
          <h3>Is any data stored?</h3>
          <p>No. Your brief is generated in memory and discarded after the artifact is built. Your seller config in <code>APPROACH.md</code> stays on your machine and is never committed.</p>
        </article>
        <article class="faq-item">
          <h3>What do I need to provide?</h3>
          <p>Just a company name and a line of context — who you are, who you're meeting, and when. The skill handles the rest across nine concurrent research batches.</p>
        </article>
        <article class="faq-item">
          <h3>Do I need to sign in?</h3>
          <p>Yes. The server uses Google OAuth. You authenticate once when you connect — no separate account creation required.</p>
        </article>
      </div>
    </section>

    <hr class="dashed" />

    {/* ---------- ALSO IN THE KIT ---------- */}
    <section class="block">
      <p class="section-label">Also in the kit</p>
      <h2 class="section-h2">The full Loadout.</h2>

      <div class="related">
        <a href="/loadout/spotter" class="related-card">
          <h3>The Spotter</h3>
          <p>Walk a product epic through nine areas. Get a structured worksheet back — critique notes, accept and skip loop, export that unlocks when every area closes.</p>
          <span class="related-cta">Open →</span>
        </a>
        <a href="/loadout/warmup" class="related-card">
          <h3>The Warmup</h3>
          <p>A daily intelligence brief for your first coffee. Curated sources, link safety scanning, live artifact.</p>
          <span class="related-cta">Open →</span>
        </a>
      </div>
    </section>

    <hr class="dashed" />

    {/* ---------- OPEN SOURCE ---------- */}
    <section class="block">
      <h2 class="section-h2">Open source.</h2>
      <p class="prose">
        The Approach ships under MIT. Use it commercially, adapt it for your team,
        embed it in your product. Source for both the skill and the MCP server lives in
        <a
          class="inline-link"
          href="https://github.com/missionbuilt/loadout"
          target="_blank"
          rel="noopener"
        >github.com/missionbuilt/loadout</a>.
      </p>
      <p class="prose">
        Save your seller context once in <code>APPROACH.md</code> at your project
        root. The skill reads it on startup and skips those intake questions on
        every repeat run.
      </p>
    </section>

    {/* ---------- CLOSER ---------- */}
    <section class="closer">
      <p>
        Know your opener. <strong>Walk up already inside the lift.</strong>
      </p>
    </section>

    {/* ---------- FOOTER ---------- */}
    <footer class="foot">
      <span>Real strength is lifting others</span>
      <a
        href="https://github.com/missionbuilt/loadout"
        target="_blank"
        rel="noopener"
      >github.com/missionbuilt/loadout</a>
    </footer>
  </main>
</BaseLayout>

<style>
  /* ============ BREADCRUMB ============ */
  .breadcrumb {
    padding: 18px var(--pad-page-x) 0;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-chalk-faint);
  }
  .breadcrumb a {
    color: var(--color-chalk-dim);
    transition: color 120ms ease-out;
  }
  .breadcrumb a:hover { color: var(--color-chalk); }
  .breadcrumb .here { color: var(--color-chalk-faint); }

  /* ============ HERO ============ */
  .hero {
    padding: 40px var(--pad-page-x) 28px;
    text-align: center;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    margin: 0 0 18px;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.24em;
    color: var(--color-blood);
    text-transform: uppercase;
  }
  .eyebrow .dots { letter-spacing: 0.04em; opacity: 0.65; }

  .display {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(56px, 11vw, 108px);
    line-height: 0.95;
    letter-spacing: -0.02em;
    color: var(--color-chalk);
    text-transform: uppercase;
  }
  .display .dot { color: var(--color-blood); }

  .live-tag {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 22px;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-army);
  }
  .live-tag .tag-sq {
    width: 8px;
    height: 8px;
    background: var(--color-army);
    display: inline-block;
  }

  .subtitle {
    margin: 22px auto 0;
    max-width: 760px;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(15px, 2.2vw, 22px);
    color: var(--color-chalk-dim);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  /* ============ META STRIP ============ */
  .meta-strip {
    margin: 28px var(--pad-page-x) 0;
    padding: 14px 0;
    border-top: var(--border-thin);
    border-bottom: var(--border-thin);
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    font-family: var(--font-mono);
    font-size: 11px;
    text-align: left;
  }
  .stat-key {
    color: var(--color-chalk-faint);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }
  .stat-value {
    margin-top: 2px;
    color: var(--color-chalk);
    font-family: var(--font-display);
    font-size: 22px;
    letter-spacing: 0.04em;
    display: inline-block;
  }
  .stat-value.linked {
    border-bottom: 1px solid transparent;
    transition: border-bottom-color 120ms ease-out, color 120ms ease-out;
  }
  .stat-value.linked:hover { border-bottom-color: currentColor; }
  .stat-value .ext {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-chalk-faint);
    letter-spacing: 0;
    transition: color 120ms ease-out;
  }
  .stat-value.linked:hover .ext { color: var(--color-chalk); }

  /* ============ BLOCK ============ */
  .block {
    padding: 56px var(--pad-page-x) 0;
    max-width: 1080px;
  }

  .section-label {
    margin: 0 0 14px;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.24em;
    color: var(--color-blood);
    text-transform: uppercase;
  }

  .section-h2 {
    margin: 0 0 18px;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 36px;
    line-height: 1.05;
    letter-spacing: 0.02em;
    color: var(--color-chalk);
    text-transform: uppercase;
  }

  .prose {
    margin: 0 0 14px;
    max-width: 760px;
    font-family: var(--font-serif);
    font-size: 17px;
    line-height: 1.65;
    color: var(--color-chalk-dim);
  }
  .prose strong { color: var(--color-chalk); font-weight: 700; }
  .prose em { font-style: italic; color: var(--color-chalk); }
  .prose code {
    font-family: var(--font-mono);
    font-size: 0.92em;
    color: var(--color-chalk);
    background: var(--color-panel);
    padding: 1px 6px;
  }
  .inline-link {
    color: var(--color-chalk);
    border-bottom: 1px dotted var(--color-rule);
    transition: color 120ms ease-out, border-color 120ms ease-out;
  }
  .inline-link:hover {
    color: var(--color-blood);
    border-bottom-color: var(--color-blood);
  }

  /* ============ ACTS GRID ============ */
  .acts {
    margin-top: 28px;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    border-top: var(--border-thin);
    border-bottom: var(--border-thin);
  }
  .act {
    padding: 28px 28px 32px;
    border-right: var(--border-thin);
  }
  .act:last-child { border-right: none; }

  .act-num {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.28em;
    color: var(--color-chalk-faint);
    text-transform: uppercase;
    margin-bottom: 14px;
  }
  .act-name {
    margin: 0 0 6px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 28px;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--color-chalk);
  }
  .act-audience {
    margin: 0 0 16px;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 13px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-blood);
  }
  .act-body {
    margin: 0 0 18px;
    font-family: var(--font-serif);
    font-size: 15px;
    line-height: 1.6;
    color: var(--color-chalk-dim);
  }
  .act-label {
    margin: 18px 0 8px;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-chalk-faint);
  }
  .act-sections {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .act-sections li {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 14px;
    line-height: 1.4;
    color: var(--color-chalk);
  }

  /* ============ AUDIENCE (2x2) ============ */
  .audience {
    margin-top: 28px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    border-top: var(--border-thin);
    border-bottom: var(--border-thin);
  }
  .audience-cell {
    padding: 24px 28px;
    border-right: var(--border-thin);
    border-bottom: var(--border-thin);
  }
  .audience-cell:nth-child(2n) { border-right: none; }
  .audience-cell:nth-last-child(-n+2) { border-bottom: none; }
  .audience-cell h3 {
    margin: 0 0 10px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 20px;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--color-chalk);
  }
  .audience-cell p {
    margin: 0;
    font-family: var(--font-serif);
    font-size: 15px;
    line-height: 1.6;
    color: var(--color-chalk-dim);
  }

  /* ============ MEDDPICC SCORECARD ============ */
  .meddpicc {
    margin-top: 28px;
    border-top: var(--border-thin);
    max-width: 640px;
  }
  .medd-row {
    display: grid;
    grid-template-columns: 28px 1fr 120px;
    gap: 20px;
    align-items: center;
    padding: 13px 0;
    border-bottom: var(--border-thin);
  }
  .medd-letter {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 20px;
    letter-spacing: 0.04em;
    color: var(--color-chalk-faint);
    text-transform: uppercase;
  }
  .medd-name {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 15px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-chalk);
  }
  .medd-state {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-align: right;
  }
  .medd-state.confirmed { color: var(--color-army); }
  .medd-state.partial   { color: var(--color-chalk-dim); }
  .medd-state.unknown   { color: var(--color-blood); }

  .medd-note {
    margin: 14px 0 0;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-chalk-faint);
  }

  /* ============ DEMO IFRAME ============ */
  /* ============ INSTALL BLOCK ============ */
  .install-block {
    padding: 56px var(--pad-page-x) 0;
    max-width: 1080px;
  }

  .install-intro {
    margin: 0 0 28px;
    max-width: 720px;
    font-family: var(--font-serif);
    font-size: 17px;
    line-height: 1.65;
    color: var(--color-chalk-dim);
  }

  .install-url {
    display: flex;
    align-items: center;
    gap: 18px;
